generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// Authentication Models (Custom JWT Auth)
// ===========================================

model User {
  id                  String         @id @default(cuid())
  name                String?
  email               String?        @unique
  emailVerified       DateTime?
  image               String?
  password            String?        // bcrypt hash (null for OAuth users)
  investorProfile     String?        // 'conservative' | 'moderate' | 'aggressive'
  plan                String         @default("free") // 'free' | 'pro' | 'elite'
  mercadoPagoPreapprovalId String?
  onboardingCompleted Boolean        @default(false)
  themePreference     String         @default("system") // 'light' | 'dark' | 'system'
  emailNotifications  Boolean        @default(false)     // Receber relatório semanal por email
  portfolios          Portfolio[]
  watchlist           Watchlist[]
  alerts              Alert[]
  goals               Goal[]
  insights            Insight[]
  weeklyReports       WeeklyReport[]
  comments            Comment[]
  votes               Vote[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([email])
}

// ===========================================
// Community
// ===========================================

model Comment {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  content   String
  type      String   @default("analysis") // "thesis" | "analysis" | "question"
  sentiment String?  // "bull" | "bear" | null
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  votes     Vote[]

  @@index([ticker, createdAt])
  @@index([userId])
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  comment   Comment  @relation(fields: [commentId], references: [id])

  @@unique([userId, commentId])
  @@index([commentId])
}

// ===========================================
// Webhook Audit Trail
// ===========================================

model WebhookEvent {
  id           String    @id @default(cuid())
  provider     String    // 'mercadopago'
  eventId      String    @unique
  eventType    String    // 'payment', 'subscription_preapproval'
  action       String?   // 'created', 'updated', etc.
  status       String    @default("received") // 'received', 'processing', 'processed', 'failed', 'skipped'
  payload      Json
  result       Json?
  errorMessage String?
  attempts     Int       @default(1)
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([eventId])
  @@index([status])
  @@index([provider, createdAt])
}

// ===========================================
// Asset Models
// ===========================================

model Asset {
  id             String        @id @default(cuid())
  ticker         String        @unique
  name           String
  type           String        // 'stock' | 'fii' | 'etf' | 'bdr'
  sector         String?
  subsector      String?
  segment        String?
  listingSegment String?       // 'Novo Mercado', 'N1', 'N2', 'Tradicional'
  cnpj           String?
  isin           String?
  isActive       Boolean       @default(true)
  fundamentals   Fundamental[]
  quotes         Quote[]
  aqScores       AqScore[]
  dividends      Dividend[]
  positions      Position[]
  transactions   Transaction[]
  watchlist      Watchlist[]
  alerts         Alert[]
  insights       Insight[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([ticker])
  @@index([type])
  @@index([sector])
}

model Fundamental {
  id               String   @id @default(cuid())
  assetId          String
  referenceDate    DateTime @db.Date
  periodType       String   // 'annual' | 'quarterly'
  // Balance Sheet
  totalAssets      Decimal? @db.Decimal(20, 2)
  totalEquity      Decimal? @db.Decimal(20, 2)
  netDebt          Decimal? @db.Decimal(20, 2)
  totalLiabilities Decimal? @db.Decimal(20, 2)
  patrimLiquido    Decimal? @db.Decimal(20, 2) // Patrimônio Líquido (CVM)
  // Income Statement
  revenue          Decimal? @db.Decimal(20, 2)
  ebitda           Decimal? @db.Decimal(20, 2)
  netIncome        Decimal? @db.Decimal(20, 2)
  eps              Decimal? @db.Decimal(10, 4) // Earnings per Share
  bvps             Decimal? @db.Decimal(10, 2) // Book Value per Share
  // Margins & Returns
  roe              Decimal? @db.Decimal(10, 4)
  roic             Decimal? @db.Decimal(10, 4)
  roa              Decimal? @db.Decimal(10, 4) // Return on Assets
  netMargin        Decimal? @db.Decimal(10, 4)
  ebitdaMargin     Decimal? @db.Decimal(10, 4)
  grossMargin      Decimal? @db.Decimal(10, 4)
  margemEbit       Decimal? @db.Decimal(10, 4) // EBIT Margin (CVM)
  margemLiquida    Decimal? @db.Decimal(10, 4) // Margem Líquida (CVM)
  // Valuation
  peRatio          Decimal? @db.Decimal(10, 2)
  pbRatio          Decimal? @db.Decimal(10, 2)
  evEbitda         Decimal? @db.Decimal(10, 2)
  psr              Decimal? @db.Decimal(10, 2) // Price/Sales
  pEbit            Decimal? @db.Decimal(10, 2) // Price/EBIT
  evEbit           Decimal? @db.Decimal(10, 2) // EV/EBIT
  pCapGiro         Decimal? @db.Decimal(10, 2) // Price/Working Capital
  pAtivCircLiq     Decimal? @db.Decimal(10, 2) // Price/Net Current Assets
  pAtivo           Decimal? @db.Decimal(10, 2) // Price/Assets
  // Dividends
  dividendYield    Decimal? @db.Decimal(10, 4)
  payoutRatio      Decimal? @db.Decimal(10, 4)
  // Debt & Liquidity
  netDebtEbitda    Decimal? @db.Decimal(10, 2)
  liquidezCorrente Decimal? @db.Decimal(10, 2) // Current Ratio
  currentRatio     Decimal? @db.Decimal(10, 2) // alias
  quickRatio       Decimal? @db.Decimal(10, 2)
  divBrutPatrim    Decimal? @db.Decimal(10, 2) // Gross Debt/Equity
  debtToEquity     Decimal? @db.Decimal(10, 2)
  // Growth & Liquidity
  crescimentoReceita5a Decimal? @db.Decimal(10, 2) // 5Y Revenue Growth %
  liq2meses        Decimal? @db.Decimal(20, 2) // 2-Month Avg Volume
  // Metadata
  source           String   @default("cvm")
  asset            Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([assetId, referenceDate, periodType])
  @@index([assetId])
  @@index([referenceDate])
}

model Quote {
  id            String   @id @default(cuid())
  assetId       String
  date          DateTime @db.Date
  open          Decimal? @db.Decimal(10, 2)
  high          Decimal? @db.Decimal(10, 2)
  low           Decimal? @db.Decimal(10, 2)
  close         Decimal  @db.Decimal(10, 2)
  adjustedClose Decimal? @db.Decimal(10, 2)
  volume        BigInt?
  changePercent Decimal? @db.Decimal(10, 4) // Daily % change
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([assetId, date])
  @@index([assetId])
  @@index([date])
}

model AqScore {
  id             String   @id @default(cuid())
  assetId        String
  calculatedAt   DateTime @default(now())
  scoreTotal     Decimal  @db.Decimal(5, 2)
  scoreValuation Decimal  @db.Decimal(5, 2)
  scoreQuality   Decimal  @db.Decimal(5, 2)
  scoreGrowth    Decimal  @db.Decimal(5, 2)
  scoreDividends Decimal  @db.Decimal(5, 2)
  scoreRisk      Decimal  @db.Decimal(5, 2)
  breakdown      Json     @default("{}")
  metadata       Json?    // Additional scoring metadata
  version        String   @default("v1")
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
  @@index([assetId])
  @@index([scoreTotal])
}

// ===========================================
// Score Tracking (Feedback Loop)
// ===========================================

model ScoreSnapshot {
  id             String   @id @default(cuid())
  ticker         String   // Ticker direto (sem FK para Asset — funciona mesmo em demo mode)
  snapshotDate   DateTime @db.Date
  scoreTotal     Decimal  @db.Decimal(5, 2)
  scoreValuation Decimal  @db.Decimal(5, 2)
  scoreQuality   Decimal  @db.Decimal(5, 2)
  scoreRisk      Decimal  @db.Decimal(5, 2)
  scoreDividends Decimal  @db.Decimal(5, 2)
  scoreGrowth    Decimal  @db.Decimal(5, 2)
  scoreMomentum  Decimal? @db.Decimal(5, 2) // Pode ser null se momentum não calculado
  classificacao  String   // 'Excepcional' | 'Saudavel' | 'Atencao' | 'Critico'
  regime         String?  // 'risk_on' | 'neutral' | 'risk_off'
  macroFactor    Decimal? @db.Decimal(4, 3) // Ex: 0.950, 1.050
  confidence     Decimal? @db.Decimal(5, 2) // 0-100
  sector         String?  // Setor na data do snapshot
  price          Decimal? @db.Decimal(10, 2) // Preço de fechamento na data
  createdAt      DateTime @default(now())

  @@unique([ticker, snapshotDate])
  @@index([ticker])
  @@index([snapshotDate])
  @@index([classificacao])
  @@index([scoreTotal])
}

model Dividend {
  id            String    @id @default(cuid())
  assetId       String
  type          String    // 'dividend' | 'jcp' | 'rendimento'
  exDate        DateTime? @db.Date
  paymentDate   DateTime? @db.Date
  valuePerShare Decimal   @db.Decimal(10, 6)
  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([assetId, exDate, type])
  @@index([assetId])
  @@index([paymentDate])
}

// ===========================================
// Portfolio Models
// ===========================================

model Portfolio {
  id               String        @id @default(cuid())
  userId           String
  name             String
  description      String?
  targetAllocation Json?         // { 'stock': 60, 'fii': 30, 'etf': 10 }
  isDefault        Boolean       @default(false)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions        Position[]
  transactions     Transaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
}

model Transaction {
  id          String    @id @default(cuid())
  portfolioId String
  assetId     String
  type        String    // 'buy' | 'sell' | 'dividend' | 'split' | 'bonus'
  date        DateTime  @db.Date
  quantity    Decimal   @db.Decimal(18, 8)
  price       Decimal   @db.Decimal(10, 2)
  total       Decimal   @db.Decimal(20, 2)
  fees        Decimal   @default(0) @db.Decimal(10, 2)
  notes       String?
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([portfolioId])
  @@index([assetId])
  @@index([date])
}

model Position {
  id          String    @id @default(cuid())
  portfolioId String
  assetId     String
  quantity    Decimal   @default(0) @db.Decimal(18, 8)
  avgCost     Decimal   @default(0) @db.Decimal(10, 2)
  totalCost   Decimal   @default(0) @db.Decimal(20, 2)
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id])
  updatedAt   DateTime  @updatedAt

  @@unique([portfolioId, assetId])
  @@index([portfolioId])
  @@index([assetId])
}

// ===========================================
// User Interaction Models
// ===========================================

model Watchlist {
  id      String   @id @default(cuid())
  userId  String
  assetId String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset   Asset    @relation(fields: [assetId], references: [id])
  addedAt DateTime @default(now())

  @@unique([userId, assetId])
  @@index([userId])
}

model Alert {
  id              String    @id @default(cuid())
  userId          String
  assetId         String
  type            String    // 'price_above' | 'price_below' | 'score_change' | 'dividend'
  threshold       Decimal?  @db.Decimal(10, 2)
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset           Asset     @relation(fields: [assetId], references: [id])
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([assetId])
  @@index([isActive])
}

// ===========================================
// Goals & Milestones Models
// ===========================================

model Goal {
  id             String      @id @default(cuid())
  userId         String
  type           String      // 'patrimony' | 'passive_income' | 'fire' | 'custom'
  name           String
  targetAmount   Decimal     @db.Decimal(20, 2)
  currentAmount  Decimal     @default(0) @db.Decimal(20, 2)
  targetDate     DateTime?   @db.Date
  monthlyContribution Decimal? @db.Decimal(10, 2)
  expectedReturn Decimal?    @db.Decimal(5, 4) // Annual return rate
  priority       Int         @default(0)
  isMain         Boolean     @default(false)
  isCompleted    Boolean     @default(false)
  completedAt    DateTime?
  notes          String?
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones     Milestone[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([type])
}

model Milestone {
  id          String    @id @default(cuid())
  goalId      String
  title       String
  targetAmount Decimal  @db.Decimal(20, 2)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([goalId])
}

// ===========================================
// Insights & Reports Models
// ===========================================

model Insight {
  id          String   @id @default(cuid())
  userId      String
  type        String   // 'valuation' | 'quality' | 'risk' | 'opportunity' | 'warning'
  category    String   // 'portfolio' | 'asset' | 'market'
  title       String
  description String   @db.Text
  assetId     String?
  data        Json     @default("{}")
  isRead      Boolean  @default(false)
  expiresAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset       Asset?   @relation(fields: [assetId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([isRead])
}

model WeeklyReport {
  id              String   @id @default(cuid())
  userId          String
  weekStart       DateTime @db.Date
  weekEnd         DateTime @db.Date
  portfolioValue  Decimal  @db.Decimal(20, 2)
  weeklyReturn    Decimal  @db.Decimal(10, 4)
  dividendsReceived Decimal @db.Decimal(10, 2)
  topPerformer    String?
  worstPerformer  String?
  alertsTriggered Int      @default(0)
  insightsCount   Int      @default(0)
  emailSentAt     DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId])
}
