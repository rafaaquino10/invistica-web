{
  "name": "invistica-web",
  "version": "0.1.0",
  "private": true,
  "description": "Research quantamental institucional aplicado a ações da B3. Invscore 0–100, valuation multi-modelo e alpha auditável.",
  "scripts": {
    "dev": "concurrently --names gateway,next --prefix-colors blue,green \"npm run gateway\" \"next dev --turbopack\"",
    "dev:next": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "gateway": "cd gateway && npx tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.2.1",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tanstack/react-query": "^5.64.1",
    "@trpc/client": "^11.0.0-rc.682",
    "@trpc/next": "^11.0.0-rc.682",
    "@trpc/react-query": "^11.0.0-rc.682",
    "@trpc/server": "^11.0.0-rc.682",
    "@types/d3": "^7.4.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^11.15.0",
    "geist": "^1.7.0",
    "jose": "^6.1.3",
    "lightweight-charts": "^5.1.0",
    "mercadopago": "^2.12.0",
    "next": "^16.2.0",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-pluggy-connect": "^2.12.0",
    "recharts": "^2.15.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.2",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.6",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.4",
    "postcss": "^8.5.1",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  }
}
