# ═══════════════════════════════════════════════════════════════
# aQ-Invest — Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Without DATABASE_URL, the app runs in demo mode (no DB needed).

# === DATABASE (Supabase PostgreSQL) ===
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# === AUTHENTICATION ===
# Generate: openssl rand -base64 32
AUTH_SECRET=
APP_URL=https://investiq.com.br

# === OAUTH PROVIDERS ===
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === GATEWAY (Express.js on Railway) ===
NEXT_PUBLIC_API_BASE_URL=https://gateway.investiq.com.br

# === CORS ===
ALLOWED_ORIGINS=https://investiq.com.br

# === MERCADO PAGO (Payments) ===
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxx
MERCADOPAGO_WEBHOOK_SECRET=

# === DATA PROVIDERS ===
BRAPI_TOKEN=
KALSHI_API_KEY=

# === OBSERVABILITY ===
SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
LOG_LEVEL=info

# === FEATURE FLAGS ===
ALLOW_DEMO=false
