# ─── aQ-Invest Gateway — Variáveis de Ambiente ─────────────
# Copie este arquivo para .env e preencha os valores.

# Porta do servidor (padrão: 4000)
PORT=4000

# brapi.dev API token (https://brapi.dev) — OBRIGATÓRIO
BRAPI_TOKEN=your_brapi_token_here

# Kalshi API key (opcional — prediction markets)
# KALSHI_API_KEY=your_kalshi_api_key_here

# Sentry DSN (opcional — observabilidade)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Log level (debug, info, warn, error)
# LOG_LEVEL=info

# CORS — origens permitidas
# ALLOWED_ORIGINS=https://aqinvest.com.br,http://localhost:3000
