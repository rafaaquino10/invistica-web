# ═══════════════════════════════════════════════════════════════
# InvestIQ Web — Variaveis de Ambiente
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores.

# === SUPABASE (Auth + Database) ===
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# === INVESTIQ API (FastAPI Backend) ===
# Em dev: http://localhost:8000
# Em prod: https://investiq-api.up.railway.app (ou seu dominio)
NEXT_PUBLIC_API_URL="http://localhost:8000"

# === APP ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# === OPCIONAL ===
# NEXT_PUBLIC_DEMO_MODE="true"     # Força modo demo (sem backend)
# ALLOW_DEMO="true"                 # Permite demo login em producao
# SENTRY_DSN=""                     # Error tracking (server-side)
# NEXT_PUBLIC_SENTRY_DSN=""         # Error tracking (client-side)
