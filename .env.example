# ═══════════════════════════════════════════════════════════════
# Invística — Variáveis de ambiente do frontend
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores.
# Variáveis NEXT_PUBLIC_* são expostas ao browser.

# === Supabase Auth ===
# Painel Supabase → Project settings → API
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# === Google OAuth (configurado no dashboard do Supabase) ===
# Authentication → Providers → Google
# Requer Client ID e Client Secret criados no Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI no Google:
#   https://SEU-PROJETO.supabase.co/auth/v1/callback
# Site URL no Supabase:
#   Production: https://invistica.com.br
#   Development: http://localhost:3000
# Redirect URLs permitidas no Supabase (wildcard):
#   http://localhost:3000/auth/callback
#   https://invistica-web.vercel.app/auth/callback
#   https://invistica.com.br/auth/callback

# === Invística API (backend FastAPI no Railway) ===
# Usada para chamadas server-side após autenticação.
INVISTICA_API_URL="https://invistica-api-production.up.railway.app"

# === Ambiente ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"
