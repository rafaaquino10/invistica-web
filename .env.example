# ═══════════════════════════════════════════════════════════════
# aQ-Invest — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores.
# Sem DATABASE_URL, o app roda em modo demo (sem banco de dados).

# === DATABASE (Supabase PostgreSQL) ===
DATABASE_URL="postgresql://user:PASSWORD@host.supabase.co:5432/postgres"
DIRECT_URL="postgresql://user:PASSWORD@db.host.supabase.co:5432/postgres"

# === AUTENTICAÇÃO (JWT Customizado) ===
# OBRIGATÓRIA — gere com: openssl rand -base64 32
AUTH_SECRET="GERAR_COM_OPENSSL_RAND_BASE64_32"
APP_URL="http://localhost:3000"

# === OAUTH PROVIDERS ===
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# === GATEWAY (Express.js) ===
GATEWAY_URL="http://localhost:4000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# === CORS ===
# ALLOWED_ORIGINS="https://investiq.com.br,http://localhost:3000"

# === MERCADO PAGO (Pagamentos) ===
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxx"
MERCADOPAGO_WEBHOOK_SECRET="your-webhook-secret"

# === DATA PROVIDERS ===
# Token brapi.dev (obrigatório no gateway)
# BRAPI_TOKEN — configure em gateway/.env
# KALSHI_API_KEY — opcional, para prediction markets

# === JOBS / CRON (Vercel) ===
# Protege /api/jobs/* — gere com: openssl rand -hex 32
# CRON_SECRET="GERAR_COM_OPENSSL_RAND_HEX_32"

# === OBSERVABILITY (Sentry) ===
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"
# LOG_LEVEL="info"

# === FEATURE FLAGS ===
ALLOW_DEMO="true"

# === AMBIENTE ===
NODE_ENV="development"
