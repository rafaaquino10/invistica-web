# ═══════════════════════════════════════════════════════════════
# InvestIQ — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores.
# Sem DATABASE_URL, o app roda em modo demo (sem banco de dados).

# === INVESTIQ BACKEND (FastAPI no Railway) ===
INVESTIQ_API_URL="https://investiqbackend-production.up.railway.app"

# === DATABASE (Supabase PostgreSQL) ===
DATABASE_URL="postgresql://user:PASSWORD@host.supabase.co:5432/postgres"
DIRECT_URL="postgresql://user:PASSWORD@db.host.supabase.co:5432/postgres"

# === AUTENTICAÇÃO (JWT Customizado) ===
# OBRIGATÓRIA — gere com: openssl rand -base64 32
AUTH_SECRET="GERAR_COM_OPENSSL_RAND_BASE64_32"
APP_URL="http://localhost:3000"

# === OAUTH PROVIDERS ===
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# === GATEWAY (Express.js — optional fallback) ===
GATEWAY_URL="http://localhost:4000"
NEXT_PUBLIC_API_BASE_URL="https://investiqbackend-production.up.railway.app"

# === MERCADO PAGO (Desabilitado — InvestIQ é 100% free) ===
# MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxx"
# MERCADOPAGO_WEBHOOK_SECRET="your-webhook-secret"

# === OBSERVABILITY (Sentry) ===
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"

# === FEATURE FLAGS ===
ALLOW_DEMO="false"
NEXT_PUBLIC_USE_MOCK_API="false"

# === AMBIENTE ===
NODE_ENV="development"
